generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Source {
  GOOGLE_FORM
  PLAIN
  MANUAL
  AGENT
  SLACK
  TELEGRAM
}

enum Stage {
  NEW
  REVIEWING
  CONTACTED
  IN_CONVO
  ONBOARDING
  WON
  PASSED
}

enum Role {
  ADMIN
  DEVREL
  SUPPORT
  ENGINEERING
}

model User {
  id           String             @id @default(cuid())
  email        String             @unique
  name         String?
  role         Role               @default(DEVREL)
  active       Boolean            @default(true)
  passwordHash String
  dashboardLayout Json?
  dashboardDefault Json?
  dashboardLayouts Json?              // named layouts: [{ id, name, layout }]
  activeLayoutId  String?             // which named layout is currently active
  savedPanels     Json?
  slackWebhook    String?            // per-user Slack incoming-webhook URL
  activities   OutreachActivity[]
  panels       SharedPanel[]
  createdAt    DateTime           @default(now())
}

model SharedPanel {
  id        String   @id @default(cuid())
  title     String
  spec      Json
  isPublic  Boolean  @default(false)
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([isPublic])
  @@index([ownerId])
}

model CronJob {
  id          String    @id @default(cuid())
  name        String
  type        String                       // handler key, e.g. "refresh_onchain"
  schedule    String                       // preset token ("15m"/"hourly"/...) or a cron expression
  enabled     Boolean   @default(true)
  config      Json?                        // job-type-specific config (e.g. slack_report spec + webhook)
  lastRunAt   DateTime?
  nextRunAt   DateTime?
  lastStatus  String?                      // "ok" | "error" | "running"
  lastResult  Json?
  lastError   String?
  createdBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([enabled])
}

model CoreJobState {
  id          String    @id @default(cuid())
  type        String    @unique          // "refresh_onchain" | "refresh_sheet"
  lastRunAt   DateTime?
  lastStatus  String?                     // "ok" | "error" | "running"
  lastResult  Json?
  lastError   String?
  updatedAt   DateTime  @updatedAt
}

model ProposedEdit {
  id           String    @id @default(cuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  changes      Json                      // [{ field, op, value, currentValue }]
  rationale    String?
  status       String    @default("pending")  // pending | approved | rejected | auto_applied
  source       String    @default("agent")    // agent | ingest | manual
  proposedBy   String?
  reviewedBy   String?
  reviewedAt   DateTime?
  createdAt    DateTime  @default(now())

  @@index([status])
  @@index([submissionId])
}

model Submission {
  id              String             @id @default(cuid())
  source          Source
  externalId      String
  submittedAt     DateTime
  project         String
  projectX        String?
  website         String?
  oneLiner        String?
  problem         String?            @db.Text
  solution        String?            @db.Text
  traction        String?            @db.Text
  funding         String?            @db.Text
  plan            String?            @db.Text
  whyBankr        String?            @db.Text
  accomplishments String?            @db.Text
  links           String?            @db.Text
  notesField      String?            @db.Text
  location        String?
  telegramTarget  String?            // Telegram chat/user id for outbound DMs (set manually or captured on inbound)
  needsHelp       String[]
  founders        Json
  score           Int                @default(0)
  scoreBreakdown  Json
  lowEffort       Boolean            @default(false)
  needsReview     Boolean            @default(false)
  reviewCandidates Json?
  stage           Stage              @default(NEW)
  owner           String?
  tokenMatch      TokenMatch?
  activities      OutreachActivity[]
  proposedEdits   ProposedEdit[]
  outboundMessages OutboundMessage[]
  outreachLog     OutreachLog[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@unique([source, externalId])
  @@index([score])
  @@index([stage])
}

// Outbound message queue. A teammate's Telegram bot (separate repo/service) POLLS
// the pending rows via GET /api/outbound/pending, sends them, and reports delivery
// via POST /api/outbound/[id]/result. Same trust model as inbound: their service is
// always the caller, bearer-authed with INGEST_API_KEY; the CRM never calls them.
// Claim-with-timeout prevents double-sends if the bot polls twice or crashes mid-send.
model OutboundMessage {
  id            String     @id @default(cuid())
  submissionId  String
  submission    Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  channel       String     @default("telegram") // future-proof; telegram for now
  target        String     // the Telegram chat/user id to deliver to
  body          String     @db.Text
  status        String     @default("pending")  // pending | claimed | sent | failed
  claimedAt     DateTime?                        // set when a poll claims it; reverts to pending after timeout
  sentAt        DateTime?
  error         String?    @db.Text
  createdBy     String?                          // who queued it (user email or 'agent')
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([status])
  @@index([submissionId])
}

// Typed outreach history, distinct from the notes/activity timeline. Each entry has
// a type (a core type or a persisted custom one), an optional detail/note, and a
// date. Surfaced as its own "Outreach History" section on the card (most-recent
// first), filterable on the Submissions page, and writable by UI / agent / Telegram.
// Custom type labels are stored on AppConfig so they're shared + reusable.
model OutreachLog {
  id           String     @id @default(cuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  type         String     // core key (reddit_post, co_marketing, pr, agent_hours, telegram_group) or a custom label
  detail       String?    @db.Text
  occurredAt   DateTime   @default(now())
  createdBy    String?    // user email or 'agent' / 'telegram'
  createdAt    DateTime   @default(now())

  @@index([submissionId])
  @@index([type])
  @@index([occurredAt])
}

model TokenMatch {
  id              String     @id @default(cuid())
  submissionId    String     @unique
  submission      Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  token           String
  wallet          String?
  matchedVia      String?
  fees24h         Float?
  contractAddress String?
  name            String?
  vol24h          Float?
  marketCapUsd    Float?
  priceChange24h  Float?
  imageUri        String?
  refreshedAt     DateTime   @default(now())
}

model OutreachActivity {
  id           String     @id @default(cuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  authorId     String
  author       User       @relation(fields: [authorId], references: [id])
  body         String     @db.Text
  kind         String     @default("note")
  createdAt    DateTime   @default(now())

  @@index([submissionId])
}

/// Tunable scoring weights (singleton row, id = "default").
model AppConfig {
  id              String   @id @default("default")
  teamSlackWebhook String?              // admin-set team-wide Slack channel webhook
  capabilityOverrides Json?             // admin-edited role→capability overrides; null cells fall back to code defaults
  customOutreachTypes Json?             // persisted custom outreach-type labels [{key,label}] added by users
  updatedAt       DateTime @updatedAt
  updatedBy       String?
}

model ScoreConfig {
  id           String   @id @default("default")
  fees         Int      @default(40)
  launched     Int      @default(15)
  traction     Int      @default(15)
  founder      Int      @default(15)
  completeness Int      @default(15)
  updatedAt    DateTime @updatedAt
  updatedBy    String?
}

/// Audit row written after each import run (powers Sources status + Import Log).
model ImportLog {
  id        String   @id @default(cuid())
  source    String   // "google" | "seed" | "plain" | "manual"
  pulled    Int      @default(0)
  created   Int      @default(0)
  updated   Int      @default(0)
  ok        Boolean  @default(true)
  message   String?
  by        String?  // email of the admin who triggered it
  createdAt DateTime @default(now())

  @@index([createdAt])
}
