# --- Database (Postgres) ---
# Local (via docker-compose): postgres on localhost:5433
DATABASE_URL="postgresql://bankr:bankr@localhost:5433/bankr_crm?schema=public"

# --- Auth ---
# Generate one: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-string"

# --- Seed user passwords (used by `npm run db:seed`) ---
SEED_ADMIN_PASSWORD="changeme-admin"
SEED_DEVREL_PASSWORD="changeme-devrel"

# --- Google Sheets importer (production source of truth) ---
# Service-account JSON (single line) with Sheets API enabled, sheet shared as viewer.
GOOGLE_SERVICE_ACCOUNT=""
GOOGLE_SHEET_ID=""
GOOGLE_SHEET_RANGE="Form Responses 1"

# --- Plain (future funnel; inert until multi-form ships) ---
PLAIN_ENABLED="false"
PLAIN_API_KEY=""
PLAIN_FORM_ID=""
